generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id              String    @id @default(uuid())
  amountPaise     Int
  category        String
  description     String?
  date            DateTime
  createdAt       DateTime  @default(now())
  idempotencyKey  String?   @unique

  @@index([category])
  @@index([date])
}